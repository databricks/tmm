# ZeroStream Configuration Template
# Copy this file to config.env and fill in your actual values
# NEVER commit config.env with real credentials!
#
# Variables are prefixed by app: FRONTEND_ for zerostream, BACKEND_ for zerobackend
# The deploy script strips prefixes when writing to app.yaml

# ============================================================================
# SHARED (both apps)
# ============================================================================
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com

# Unity Catalog table (3-level namespace) - used by both apps
ZEROBUS_CATALOG=demo_catalog
ZEROBUS_SCHEMA=zerostream
ZEROBUS_TABLE=sensor_data

# ============================================================================
# FRONTEND - ZeroStream (sensor collection app)
# Collects mobile sensor data and pushes to ZeroBus
# ============================================================================

# Service Principal for ZeroBus authentication
# Create via: Databricks Console > Settings > Identity and Access > Service Principals
FRONTEND_SERVICE_PRINCIPAL_ID=12345678-1234-1234-1234-123456789abc
FRONTEND_SERVICE_PRINCIPAL_SECRET=dapi1234567890abcdefghijklmnopqrstuvwxyz

# ZeroBus streaming endpoint
# Format: <workspace_id>.zerobus.<region>.cloud.databricks.com
FRONTEND_ZEROBUS_ENDPOINT=workspace-id.zerobus.us-west-2.cloud.databricks.com

# ============================================================================
# BACKEND - ZeroBackend (dashboard app)
# Reads data via SQL Warehouse (ZeroBus view) and Lakebase (map view)
# ============================================================================

# PAT token for SQL Warehouse access
BACKEND_DATABRICKS_TOKEN=dapi1234567890abcdefghijklmnopqrstuvwxyz

# SQL Warehouse settings (for ZeroBus streaming data view)
BACKEND_SQL_WAREHOUSE_ID=1234567890abcdef
BACKEND_SQL_WAREHOUSE_HTTP_PATH=/sql/1.0/warehouses/1234567890abcdef

# Frontend URL for QR code generation
BACKEND_FRONTEND_URL=https://zerostream.aws.databricksapps.com

# Default data source: "zerobus" or "lakebase"
BACKEND_DEFAULT_DATA_SOURCE=zerobus

# ----------------------------------------------------------------------------
# Lakebase Autoscaling (optional - for map dashboard view)
# Uses OAuth via w.postgres.generate_database_credential() API
# Note: No prefix needed - Lakebase is backend-only
# ----------------------------------------------------------------------------

# Lakebase endpoint hostname (without https://)
LAKEBASE_HOST=ep-abc12345.database.us-west-2.cloud.databricks.com

# CRITICAL: Use project UUID, NOT display name
# Find via: w.postgres.list_projects() -> project.uid
LAKEBASE_PROJECT=12345678-1234-1234-1234-123456789abc

# Branch name (e.g., br-proud-rain-d19jvx11)
LAKEBASE_BRANCH=br-main-abc12345

# Endpoint name (e.g., ep-green-feather-d1ziwnzh)
LAKEBASE_ENDPOINT=ep-default-abc12345

# PostgreSQL table (2-level namespace - replicated from Unity Catalog)
LAKEBASE_CATALOG=zerostream
LAKEBASE_SCHEMA=public
LAKEBASE_TABLE=sensor_data

# ============================================================================
# Setup Instructions
# ============================================================================
# 1. Copy this file: cp config.env.example config.env
# 2. Fill in your actual values in config.env
# 3. Follow ZEROBUS_SETUP_GUIDE.md for database setup
# 4. Deploy: /deploy (both apps) or /deploy zerostream / /deploy zerobackend
# 5. For Lakebase setup, see CLAUDE.md "Lakebase Autoscaling Setup"
